generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  COMERCIAL
  LECTURA
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  role      UserRole  @default(COMERCIAL)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
}
