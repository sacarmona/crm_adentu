generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Architecture note: the schema is intentionally single-tenant for ADENTU.
/// If the CRM is offered to another company later, add tenantId consistently
/// to business-owned records before implementing shared deployments.

enum UserRole {
  ADMIN
  COMERCIAL
  LECTURA
}

enum CompanyStatus {
  UNQUALIFIED
  PROSPECTING
  HISTORIC_CLIENT
  ACTIVE_CLIENT
  LOST
  DISCARDED
}

enum ContactStatus {
  UNQUALIFIED
  QUALIFIED_POSITIVE
  WITH_OPPORTUNITY
  CLIENT
  LOST
  QUALIFIED_NEGATIVE
}

enum LeadSource {
  INBOUND_EMAIL
  INBOUND_PHONE_WHATSAPP
  INBOUND_OTHER
  OUTBOUND_CONSULTATIVE
  OUTBOUND_RELATIONAL
  OUTBOUND_FAIRS
  OUTBOUND_OTHER
}

enum OpportunityStatus {
  EXPLORATION
  PROPOSAL_SENT
  NEGOTIATION
  WON
  STALLED
  LOST
}

enum Certainty {
  HIGH
  MEDIUM
  LOW
}

enum Currency {
  CLP
  UF
  USD
  EUR
}

enum InteractionType {
  EMAIL
  WHATSAPP
  PHONE
  LINKEDIN
  NEW_FOCUS_CLIENT_MEETING
  ONLINE_MEETING
  IN_PERSON_MEETING
  PROPOSAL_SENT
  FOLLOW_UP
  CLIENT_RESPONSE
  OTHER
}

enum EmailProvider {
  GMAIL
  MICROSOFT
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum EmailClassificationStatus {
  PROPOSED
  APPROVED
  IGNORED
}

enum EmailCommercialIntent {
  INQUIRY
  OPPORTUNITY
  FOLLOW_UP
  PROPOSAL
  NEGOTIATION
  SUPPORT
  ADMINISTRATIVE
  OTHER
}

enum EmailDraftStatus {
  DRAFT
  APPROVED
  DISCARDED
}

enum EmailDiscardRuleType {
  SENDER_EXACT
  SENDER_DOMAIN
  SUBJECT_CONTAINS
}

enum CalendarMeetingStatus {
  SCHEDULED
  COMPLETED
  IMPORTED
  IGNORED
}

enum TaskStatus {
  PENDING
  EXECUTED
  CLOSED
}

enum AiInsightType {
  INTERACTION_ANALYSIS
  NEXT_ACTION_SUGGESTION
  FOLLOW_UP_EMAIL
  COMPANY_HISTORY_SUMMARY
  DORMANT_OPPORTUNITY_DETECTION
  INCOMPLETE_COMPANY_DETECTION
  CONTACT_WITHOUT_FOLLOW_UP_DETECTION
}

enum AiInsightStatus {
  DRAFT
  PROPOSED
  APPROVED
  REJECTED
}

enum CommercialSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ImportBatchStatus {
  DRAFT
  VALIDATING
  READY
  IMPORTED
  FAILED
  CANCELLED
}

enum ImportRowStatus {
  PENDING
  VALID
  WARNING
  ERROR
  IMPORTED
  SKIPPED
}

enum AuditAction {
  CREATE
  UPDATE
  STAGE_CHANGE
  SOFT_DELETE
  IMPORT
  AI_SUGGESTION_APPROVAL
}

enum AttachmentEntityType {
  COMPANY
  CONTACT
  OPPORTUNITY
  INTERACTION
  TASK
  PLAYBOOK
}

enum PlaybookItemType {
  KEY_QUESTION
  QUALIFICATION_CRITERIA
  COMMON_OBJECTION
  SUGGESTED_NEXT_STEP
  PROPOSAL_CHECKLIST
  SUGGESTED_DOCUMENT
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(COMERCIAL)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts                     Account[]
  sessions                     Session[]
  responsibleCompanies         Company[]                @relation("CompanyResponsible")
  responsibleContacts          Contact[]                @relation("ContactResponsible")
  responsibleOpportunities     Opportunity[]            @relation("OpportunityResponsible")
  executedInteractions         Interaction[]            @relation("InteractionExecutor")
  assignedTasks                Task[]                   @relation("TaskAssignee")
  createdTasks                 Task[]                   @relation("TaskCreator")
  importBatches                ImportBatch[]            @relation("ImportBatchCreator")
  auditLogs                    AuditLog[]               @relation("AuditActor")
  approvedAiInsights           AiInsight[]              @relation("AiInsightApprover")
  reviewedEmailClassifications EmailClassification[]    @relation("EmailClassificationReviewer")
  reviewedEmailDrafts          EmailDraft[]             @relation("EmailDraftReviewer")
  emailDiscardRules            EmailDiscardRule[]
  createdPlaybooks             Playbook[]               @relation("PlaybookCreator")
  commercialMilestones         CommercialMilestone[]    @relation("MilestoneOwner")
  aiSettingsUpdates            AiSettings[]
  emailConnections             EmailConnection[]
  reviewedWhatsAppMessages     WhatsAppMessage[]        @relation("WhatsAppMessageReviewer")
  whatsAppDiscardRules         WhatsAppDiscardRule[]
  whatsAppThreadAnalyses       WhatsAppThreadAnalysis[]
  calendarConnection           CalendarConnection?
  calendarMeetings             CalendarMeeting[]

  @@index([email])
  @@index([role])
}

model EmailConnection {
  id                    String        @id @default(uuid())
  userId                String
  provider              EmailProvider
  emailAddress          String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  scope                 String?
  syncCursor            String?
  lastSyncedAt          DateTime?
  lastError             String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages EmailMessage[]

  @@unique([userId, provider])
  @@index([emailAddress])
}

model CalendarConnection {
  id                    String    @id @default(uuid())
  userId                String    @unique
  emailAddress          String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  scope                 String?
  lastSyncedAt          DateTime?
  lastError             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarMeeting {
  id                   String                @id @default(uuid())
  userId               String
  providerEventId      String
  summary              String
  description          String?
  meetingUri           String?
  conferenceId         String?
  startsAt             DateTime
  endsAt               DateTime?
  attendees            Json?
  organizerEmail       String?
  status               CalendarMeetingStatus @default(SCHEDULED)
  minutes              String?
  importedInteractionId String?               @unique
  companyId            String?
  contactId            String?
  opportunityId        String?
  serviceId            String?
  lastSyncedAt         DateTime              @default(now())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedInteraction Interaction? @relation(fields: [importedInteractionId], references: [id])
  company             Company?     @relation(fields: [companyId], references: [id])
  contact             Contact?     @relation(fields: [contactId], references: [id])
  opportunity         Opportunity? @relation(fields: [opportunityId], references: [id])
  service             Service?     @relation(fields: [serviceId], references: [id])

  @@unique([userId, providerEventId])
  @@index([startsAt])
  @@index([status])
  @@index([companyId])
  @@index([contactId])
  @@index([opportunityId])
}

model EmailMessage {
  id                String         @id @default(uuid())
  connectionId      String
  providerMessageId String
  threadId          String?
  direction         EmailDirection
  fromAddress       String
  fromName          String?
  toAddresses       Json
  ccAddresses       Json?
  subject           String?
  snippet           String?
  body              String?
  sentAt            DateTime
  isRead            Boolean        @default(false)
  interactionId     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  connection     EmailConnection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  interaction    Interaction?         @relation(fields: [interactionId], references: [id])
  classification EmailClassification?
  draft          EmailDraft?

  @@unique([connectionId, providerMessageId])
  @@index([sentAt])
  @@index([fromAddress])
  @@index([interactionId])
}

model EmailDraft {
  id             String           @id @default(uuid())
  emailMessageId String           @unique
  status         EmailDraftStatus @default(DRAFT)
  subject        String
  body           String
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  emailMessage EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("EmailDraftReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([reviewedById])
}

model EmailClassification {
  id                   String                    @id @default(uuid())
  emailMessageId       String                    @unique
  status               EmailClassificationStatus @default(PROPOSED)
  isCommercial         Boolean
  confidence           Decimal                   @db.Decimal(5, 4)
  summary              String
  intent               EmailCommercialIntent
  sentiment            CommercialSentiment
  suggestedNextAction  String?
  suggestedDueDate     DateTime?
  matchedContactId     String?
  matchedCompanyId     String?
  matchedOpportunityId String?
  reviewedById         String?
  reviewedAt           DateTime?
  discardRuleId        String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  emailMessage EmailMessage      @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  reviewedBy   User?             @relation("EmailClassificationReviewer", fields: [reviewedById], references: [id])
  discardRule  EmailDiscardRule? @relation(fields: [discardRuleId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([isCommercial])
  @@index([matchedContactId])
  @@index([matchedCompanyId])
  @@index([matchedOpportunityId])
  @@index([discardRuleId])
}

model EmailDiscardRule {
  id         String               @id @default(uuid())
  userId     String
  type       EmailDiscardRuleType
  value      String
  direction  EmailDirection?
  isActive   Boolean              @default(true)
  matchCount Int                  @default(0)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  classifications EmailClassification[]

  @@unique([userId, type, value, direction])
  @@index([userId, isActive])
  @@index([type])
}

enum WhatsAppDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  PENDING
  LINKED
  IGNORED
}

model WhatsAppMessage {
  id                   String                @id @default(uuid())
  waMessageId          String                @unique
  direction            WhatsAppDirection
  fromNumber           String
  toNumber             String
  contactName          String?
  body                 String?
  mediaType            String?
  mediaId              String?
  timestamp            DateTime
  status               WhatsAppMessageStatus @default(PENDING)
  matchedContactId     String?
  matchedCompanyId     String?
  matchedOpportunityId String?
  interactionId        String?
  discardRuleId        String?
  reviewedById         String?
  reviewedAt           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  interaction Interaction?         @relation(fields: [interactionId], references: [id])
  discardRule WhatsAppDiscardRule? @relation(fields: [discardRuleId], references: [id])
  reviewedBy  User?                @relation("WhatsAppMessageReviewer", fields: [reviewedById], references: [id])

  @@index([fromNumber])
  @@index([timestamp])
  @@index([status])
  @@index([interactionId])
}

model WhatsAppDiscardRule {
  id          String   @id @default(uuid())
  phoneNumber String   @unique
  isActive    Boolean  @default(true)
  matchCount  Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User              @relation(fields: [createdById], references: [id])
  messages  WhatsAppMessage[]

  @@index([isActive])
}

model WhatsAppThreadAnalysis {
  id                   String                @id @default(uuid())
  phoneNumber          String                @unique
  isCommercial         Boolean
  confidence           Decimal               @db.Decimal(5, 4)
  summary              String
  intent               EmailCommercialIntent
  sentiment            CommercialSentiment
  suggestedNextAction  String?
  suggestedDueDate     DateTime?
  matchedContactId     String?
  matchedCompanyId     String?
  matchedOpportunityId String?
  taskCreatedId        String?               @unique
  analyzedById         String
  analyzedAt           DateTime              @default(now())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  analyzedBy  User  @relation(fields: [analyzedById], references: [id])
  taskCreated Task? @relation(fields: [taskCreatedId], references: [id])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id              String        @id @default(uuid())
  name            String
  normalizedName  String
  industry        String?
  region          String?
  status          CompanyStatus @default(UNQUALIFIED)
  size            String?
  responsibleId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastInteraction DateTime?
  activeDeals     Int           @default(0)
  totalWon        Decimal       @default(0) @db.Decimal(18, 2)
  contactCount    Int           @default(0)
  completeness    Int           @default(0)
  notes           String?
  deletedAt       DateTime?

  responsible              User?                 @relation("CompanyResponsible", fields: [responsibleId], references: [id])
  contacts                 Contact[]
  opportunities            Opportunity[]
  interactions             Interaction[]
  tasks                    Task[]
  ownedMarketAssets        MarketAsset[]         @relation("MarketAssetOwnerCompany")
  constructionMarketAssets MarketAsset[]         @relation("MarketAssetConstructionCompany")
  omMarketAssets           MarketAsset[]         @relation("MarketAssetOmCompany")
  commercialMilestones     CommercialMilestone[]
  attachments              Attachment[]
  calendarMeetings         CalendarMeeting[]

  @@index([name])
  @@index([normalizedName])
  @@index([status])
  @@index([industry])
  @@index([region])
  @@index([responsibleId])
  @@index([lastInteraction])
}

model Contact {
  id              String        @id @default(uuid())
  name            String
  companyId       String?
  roleArea        String?
  status          ContactStatus @default(UNQUALIFIED)
  email           String?
  phone           String?
  leadSource      LeadSource?
  responsibleId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastInteraction DateTime?
  activeDeals     Int           @default(0)
  completeness    Int           @default(0)
  notes           String?
  deletedAt       DateTime?

  company              Company?      @relation(fields: [companyId], references: [id])
  responsible          User?         @relation("ContactResponsible", fields: [responsibleId], references: [id])
  primaryOpportunities Opportunity[] @relation("OpportunityPrimaryContact")
  interactions         Interaction[]
  tasks                Task[]
  attachments          Attachment[]
  calendarMeetings     CalendarMeeting[]

  @@index([companyId])
  @@index([email])
  @@index([status])
  @@index([leadSource])
  @@index([responsibleId])
  @@index([lastInteraction])
}

model Opportunity {
  id                 String            @id @default(uuid())
  name               String
  primaryContactId   String?
  companyId          String?
  serviceId          String?
  status             OpportunityStatus @default(EXPLORATION)
  certainty          Certainty?
  probability        Decimal           @default(0) @db.Decimal(5, 4)
  ageDays            Int               @default(0)
  businessUnit       String?
  currency           Currency          @default(CLP)
  price              Decimal           @default(0) @db.Decimal(18, 2)
  exchangeRate       Decimal           @default(1) @db.Decimal(18, 6)
  priceClp           Decimal           @default(0) @db.Decimal(18, 2)
  quantity           Decimal           @default(1) @db.Decimal(18, 4)
  monthlyAmount      Decimal           @default(0) @db.Decimal(18, 2)
  months             Int               @default(1)
  totalAmount        Decimal           @default(0) @db.Decimal(18, 2)
  weightedAmount     Decimal           @default(0) @db.Decimal(18, 2)
  estimatedCloseDate DateTime?
  estimatedStartDate DateTime?
  nextActionDate     DateTime?
  responsibleId      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  lastInteraction    DateTime?
  completeness       Int               @default(0)
  notes              String?
  deletedAt          DateTime?

  primaryContact Contact?      @relation("OpportunityPrimaryContact", fields: [primaryContactId], references: [id])
  company        Company?      @relation(fields: [companyId], references: [id])
  service        Service?      @relation(fields: [serviceId], references: [id])
  responsible    User?         @relation("OpportunityResponsible", fields: [responsibleId], references: [id])
  interactions   Interaction[]
  tasks          Task[]
  aiInsights     AiInsight[]
  attachments    Attachment[]
  calendarMeetings CalendarMeeting[]

  @@index([status])
  @@index([companyId])
  @@index([primaryContactId])
  @@index([serviceId])
  @@index([responsibleId])
  @@index([estimatedCloseDate])
  @@index([nextActionDate])
  @@index([lastInteraction])
}

model Interaction {
  id                String          @id @default(uuid())
  date              DateTime        @default(now())
  contactId         String?
  opportunityId     String?
  companyId         String?
  executedById      String?
  type              InteractionType
  content           String
  nextAction        String?
  nextActionDate    DateTime?
  nextActionDueDate DateTime?
  nextActionStatus  TaskStatus?
  serviceId         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  contact          Contact?          @relation(fields: [contactId], references: [id])
  opportunity      Opportunity?      @relation(fields: [opportunityId], references: [id])
  company          Company?          @relation(fields: [companyId], references: [id])
  executedBy       User?             @relation("InteractionExecutor", fields: [executedById], references: [id])
  service          Service?          @relation(fields: [serviceId], references: [id])
  tasks            Task[]
  aiInsights       AiInsight[]
  attachments      Attachment[]
  emailMessages    EmailMessage[]
  whatsAppMessages WhatsAppMessage[]
  calendarMeeting  CalendarMeeting?

  @@index([companyId])
  @@index([contactId])
  @@index([opportunityId])
  @@index([date])
  @@index([executedById])
  @@index([serviceId])
}

model Task {
  id            String     @id @default(uuid())
  title         String
  description   String?
  status        TaskStatus @default(PENDING)
  dueDate       DateTime?
  executedAt    DateTime?
  result        String?
  companyId     String?
  contactId     String?
  opportunityId String?
  interactionId String?
  serviceId     String?
  assignedToId  String?
  createdById   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  calendarEventId  String?
  calendarOwnerId  String?
  calendarSyncedAt DateTime?
  calendarError    String?

  company                Company?                 @relation(fields: [companyId], references: [id])
  contact                Contact?                 @relation(fields: [contactId], references: [id])
  opportunity            Opportunity?             @relation(fields: [opportunityId], references: [id])
  interaction            Interaction?             @relation(fields: [interactionId], references: [id])
  service                Service?                 @relation(fields: [serviceId], references: [id])
  assignedTo             User?                    @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy              User?                    @relation("TaskCreator", fields: [createdById], references: [id])
  whatsAppThreadAnalyses WhatsAppThreadAnalysis[]

  @@index([dueDate])
  @@index([status])
  @@index([assignedToId])
  @@index([companyId])
  @@index([opportunityId])
}

model MarketAsset {
  id                    String    @id @default(uuid())
  ownerName             String?
  unitName              String
  serviceId             String?
  quantity              Decimal   @default(1) @db.Decimal(18, 4)
  constructionCompany   String?
  operationMaintenance  String?
  otherRole             String?
  comment               String?
  ownerCompanyId        String?
  constructionCompanyId String?
  omCompanyId           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  service                Service? @relation(fields: [serviceId], references: [id])
  ownerCompany           Company? @relation("MarketAssetOwnerCompany", fields: [ownerCompanyId], references: [id])
  constructionCompanyRef Company? @relation("MarketAssetConstructionCompany", fields: [constructionCompanyId], references: [id])
  omCompany              Company? @relation("MarketAssetOmCompany", fields: [omCompanyId], references: [id])

  @@index([serviceId])
  @@index([ownerName])
  @@index([constructionCompany])
  @@index([operationMaintenance])
}

model CommercialMilestone {
  id        String    @id @default(uuid())
  date      DateTime
  companyId String?
  project   String
  industry  String?
  ownerId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company? @relation(fields: [companyId], references: [id])
  owner   User?    @relation("MilestoneOwner", fields: [ownerId], references: [id])

  @@index([date])
  @@index([companyId])
  @@index([industry])
}

model Service {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  opportunities Opportunity[]
  interactions  Interaction[]
  tasks         Task[]
  marketAssets  MarketAsset[]
  playbooks     Playbook[]
  calendarMeetings CalendarMeeting[]

  @@index([slug])
  @@index([isActive])
}

model DictionaryValue {
  id          String    @id @default(uuid())
  type        String
  key         String
  label       String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([type, key])
  @@index([type])
  @@index([isActive])
}

model Playbook {
  id          String    @id @default(uuid())
  name        String
  serviceId   String?
  description String?
  createdById String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  service     Service?       @relation(fields: [serviceId], references: [id])
  createdBy   User?          @relation("PlaybookCreator", fields: [createdById], references: [id])
  items       PlaybookItem[]
  attachments Attachment[]

  @@index([serviceId])
  @@index([isActive])
}

model PlaybookItem {
  id         String           @id @default(uuid())
  playbookId String
  type       PlaybookItemType
  title      String
  content    String
  sortOrder  Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?

  playbook Playbook @relation(fields: [playbookId], references: [id])

  @@index([playbookId])
  @@index([type])
}

enum AiProvider {
  OPENAI
  ANTHROPIC
}

// Singleton row (fixed id "default") holding the AI provider an Admin
// selected at runtime, so it can be switched without a redeploy.
model AiSettings {
  id             String     @id @default("default")
  activeProvider AiProvider @default(OPENAI)
  updatedById    String?
  updatedAt      DateTime   @updatedAt

  updatedBy User? @relation(fields: [updatedById], references: [id])
}

model AiInsight {
  id                          String               @id @default(uuid())
  type                        AiInsightType
  status                      AiInsightStatus      @default(PROPOSED)
  interactionId               String?
  companyId                   String?
  contactId                   String?
  opportunityId               String?
  summary                     String?
  customerInterests           Json?
  objections                  Json?
  commitments                 Json?
  risks                       Json?
  suggestedNextSteps          Json?
  mentionedServices           Json?
  sentiment                   CommercialSentiment?
  suggestedAdvanceProbability Decimal?             @db.Decimal(5, 4)
  suggestedChanges            Json?
  approvedById                String?
  approvedAt                  DateTime?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  deletedAt                   DateTime?

  interaction Interaction? @relation(fields: [interactionId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  approvedBy  User?        @relation("AiInsightApprover", fields: [approvedById], references: [id])

  @@index([type])
  @@index([status])
  @@index([interactionId])
  @@index([companyId])
  @@index([contactId])
  @@index([opportunityId])
}

model ImportBatch {
  id          String            @id @default(uuid())
  fileName    String
  source      String            @default("excel")
  status      ImportBatchStatus @default(DRAFT)
  createdById String?
  summary     Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  importedAt  DateTime?

  createdBy User?       @relation("ImportBatchCreator", fields: [createdById], references: [id])
  rows      ImportRow[]

  @@index([status])
  @@index([createdAt])
}

model ImportRow {
  id              String          @id @default(uuid())
  importBatchId   String
  sheetName       String
  rowNumber       Int
  targetModel     String
  status          ImportRowStatus @default(PENDING)
  rawData         Json
  normalizedData  Json?
  issues          Json?
  createdEntityId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([importBatchId])
  @@index([sheetName])
  @@index([targetModel])
  @@index([status])
}

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType String
  entityId   String
  actorId    String?
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([action])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Attachment {
  id            String               @id @default(uuid())
  fileName      String
  mimeType      String?
  url           String
  sizeBytes     Int?
  entityType    AttachmentEntityType
  entityId      String
  companyId     String?
  contactId     String?
  opportunityId String?
  interactionId String?
  playbookId    String?
  createdAt     DateTime             @default(now())
  deletedAt     DateTime?

  company     Company?     @relation(fields: [companyId], references: [id])
  contact     Contact?     @relation(fields: [contactId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  interaction Interaction? @relation(fields: [interactionId], references: [id])
  playbook    Playbook?    @relation(fields: [playbookId], references: [id])

  @@index([entityType, entityId])
  @@index([companyId])
  @@index([contactId])
  @@index([opportunityId])
}
